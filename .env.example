# LLM provider configuration
# FAST_LLM is used for quizzes and flashcards.
FAST_LLM_API_KEY=your_fast_api_key
FAST_LLM_BASE_URL=https://api.openai.com
FAST_LLM_MODEL=openai/gpt-oss-120b
FAST_LLM_TIMEOUT_MS=30000

# HEAVY_LLM is used for RAG, reader explanations, and syllabus drafting.
HEAVY_LLM_API_KEY=your_heavy_api_key
HEAVY_LLM_BASE_URL=https://api.openai.com
HEAVY_LLM_MODEL=openai/gpt-oss-120b
HEAVY_LLM_TIMEOUT_MS=30000

# Optional aliases supported by the app
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# LLM_TIMEOUT_MS=
# OPENAI_API_KEY=
# OPENAI_ENDPOINT=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# BASE_MODEL=
# API_KEY=
# BASE_URL=
# MODEL=
# TIMEOUT_MS=
