  style Backend fill:#eff6ff,stroke:#93c5fd,stroke-width:1px
  style Data fill:#eef2ff,stroke:#bfdbfe,stroke-width:1px
  style Ingest fill:#f0fdf4,stroke:#86efac,stroke-width:1px
